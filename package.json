    "axios": "^1.6.8",
    "bcryptjs": "^2.4.3",
    "canvas-confetti": "^1.9.3",
    "cloudinary": "^2.10.0",
    "framer-motion": "^11.1.7",
    "iconv-lite": "^0.7.3",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.368.0",
    "next": "^14.2.1",
    "nodemailer": "^6.9.13",
    "pdfkit": "^0.15.0",
    "razorpay": "^2.9.2",
